{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npx expo export -p web",
  "outputDirectory": "dist",
  "installCommand": "npm install --legacy-peer-deps",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://quran-school-lms.vercel.app/api/:path*" },
    { "source": "/dev", "destination": "https://quran-school-lms.vercel.app/dev" },
    { "source": "/dev/:path*", "destination": "https://quran-school-lms.vercel.app/dev/:path*" },
    { "source": "/_next/:path*", "destination": "https://quran-school-lms.vercel.app/_next/:path*" },
    { "source": "/((?!api|dev|_next|_expo|assets|favicon.ico|.*\\.).*)", "destination": "/index.html" }
  ]
}
